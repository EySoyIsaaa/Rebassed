<Window x:Class="Rebassed.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Rebassed.Desktop.Views"
        mc:Ignorable="d"
        Title="Rebassed MP3 Builder" Height="760" Width="860" MinHeight="720" MinWidth="800">
    <Window.Resources>
        <views:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Files" Padding="10" Margin="0 0 0 10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="0" Margin="0 0 8 8" Text="{Binding InputFile, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="0" Grid.Column="1" Content="Open MP3" Padding="14 6" Command="{Binding BrowseInputCommand}"/>

                <TextBox Grid.Row="1" Margin="0 0 8 0" Text="{Binding OutputFile, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Row="1" Grid.Column="1" Content="Export MP3" Padding="14 6" Command="{Binding BrowseOutputCommand}"/>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0 0 0 10">
            <ComboBox Width="200" Margin="0 0 8 0" ItemsSource="{Binding PresetNames}" SelectedItem="{Binding SelectedPreset}"/>
            <Button Content="Apply Preset" Padding="12 6" Command="{Binding ApplyPresetCommand}"/>
            <Button Content="Process" Padding="22 6" Margin="16 0 0 0" Command="{Binding ProcessCommand}"/>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="DSP Controls" Margin="0 0 6 0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Target Frequency (Hz)" FontWeight="SemiBold"/>
                    <Slider x:Name="TargetSlider" Minimum="25" Maximum="45" Value="{Binding Parameters.TargetFrequencyHz}"/>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=TargetSlider, Path=Value, StringFormat=F1}"/>

                    <TextBlock Text="Sweep" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <Slider x:Name="SweepLow" Width="180" Minimum="30" Maximum="70" Value="{Binding Parameters.SweepLowHz}"/>
                        <Slider x:Name="SweepHigh" Width="180" Margin="8 0 0 0" Minimum="70" Maximum="130" Value="{Binding Parameters.SweepHighHz}"/>
                    </StackPanel>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=SweepLow, Path=Value, StringFormat='Low {0:F0} Hz'}"/>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=SweepHigh, Path=Value, StringFormat='High {0:F0} Hz'}"/>

                    <TextBlock Text="Wide" FontWeight="SemiBold"/>
                    <Slider x:Name="WideSlider" Minimum="0.2" Maximum="1.0" Value="{Binding Parameters.Wide}"/>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=WideSlider, Path=Value, StringFormat=F2}"/>

                    <TextBlock Text="Bass Level" FontWeight="SemiBold"/>
                    <Slider x:Name="BassSlider" Minimum="-18" Maximum="0" Value="{Binding Parameters.BassLevelDb}"/>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=BassSlider, Path=Value, StringFormat='{}{0:F1} dB'}"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Safety & Mix" Grid.Column="1" Margin="6 0 0 0" Padding="12">
                <StackPanel>
                    <TextBlock Text="Subsonic HPF" FontWeight="SemiBold"/>
                    <Slider x:Name="HpfSlider" Minimum="15" Maximum="40" Value="{Binding Parameters.SubsonicHpfHz}"/>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=HpfSlider, Path=Value, StringFormat='{}{0:F1} Hz'}"/>

                    <TextBlock Text="Dry/Wet Mix" FontWeight="SemiBold"/>
                    <Slider x:Name="MixSlider" Minimum="0" Maximum="1" Value="{Binding Parameters.DryWetMix}"/>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=MixSlider, Path=Value, StringFormat=F2}"/>

                    <TextBlock Text="Output Ceiling" FontWeight="SemiBold"/>
                    <Slider x:Name="CeilSlider" Minimum="-12" Maximum="-0.1" Value="{Binding Parameters.OutputCeilingDb}"/>
                    <TextBlock Margin="0 0 0 8" Text="{Binding ElementName=CeilSlider, Path=Value, StringFormat='{}{0:F1} dBFS'}"/>

                    <TextBlock Text="Peak" FontWeight="SemiBold"/>
                    <ProgressBar Height="18" Maximum="1" Value="{Binding Peak}"/>
                    <TextBlock Margin="0 4 0 0" Foreground="DarkRed" FontWeight="Bold" Text="CLIPPING DETECTED" Visibility="{Binding Clipping, Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <Border Margin="0 12 0 0" BorderBrush="DarkOrange" BorderThickness="1" CornerRadius="5" Padding="8">
                        <TextBlock TextWrapping="Wrap" Text="{Binding BoxWarning}" Foreground="DarkOrange"/>
                    </Border>
                </StackPanel>
            </GroupBox>
        </Grid>

        <TextBlock Grid.Row="3" Margin="0 10 0 0" Text="{Binding Status}" FontWeight="SemiBold"/>
    </Grid>
</Window>
